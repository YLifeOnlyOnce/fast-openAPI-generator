{
  "name": "openapi-typescript-sdk",
  "version": "1.0.0",
  "description": "将OpenAPI规范转换为TypeScript SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "generate": "ts-node src/cli.ts",
    "test": "jest",
    "prepublishOnly": "npm run build",
    "publish:patch": "node scripts/publish.js patch",
    "publish:minor": "node scripts/publish.js minor",
    "publish:major": "node scripts/publish.js major",
    "generate-sdk": "npm run generate -- generate -i example/petstore.yaml -o sdk",
    "update-sdk": "node scripts/update-sdk.js"
  },
  "keywords": [
    "openapi",
    "swagger",
    "typescript",
    "sdk",
    "generator"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@openapitools/openapi-generator-cli": "^2.22.0",
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "glob": "^10.3.3",
    "js-yaml": "^4.1.0",
    "openapi-types": "^12.1.3",
    "prettier": "^3.0.3",
    "swagger-typescript-api": "^13.2.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.4",
    "@types/js-yaml": "^4.0.5",
    "@types/node": "^20.5.9",
    "axios": "^1.5.0",
    "jest": "^29.6.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "peerDependencies": {
    "axios": "^1.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
